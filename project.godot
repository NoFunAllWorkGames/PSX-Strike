[display]

window/size/viewport_width=426
window/size/viewport_height=240
window/size/mode=4
window/size/initial_position_type=3
window/size/initial_position=Vector2i(943, 239)
window/size/initial_screen=1
window/size/window_width_override=1704
window/size/window_height_override=960
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="PSXStrike"

[file_customization]

folder_colors={
"res://assets/": "blue",
"res://scenes/": "green",
"res://src/": "red"
}

